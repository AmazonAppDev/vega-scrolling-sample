{
  "name": "keplerscrollingapp",
  "version": "0.0.2",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf node_modules buildinfo.json dist bvm build",
    "start": "react-native start",
    "test": "jest --colors --passWithNoTests",
    "test:snapshot": "jest --colors --updateSnapshot",
    "perfTest": "kepler exec perf kpi-visualizer --app-name com.amazondeveloper.keplerscrollingapp --iterations 10  --kpi ui-fluidity --test-scenario test/performance/generalTest.py",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "build": "react-native build-kepler --build-type Release",
    "build:release": "react-native build-kepler --build-type Release",
    "build:debug": "react-native build-kepler --build-type Debug",
    "build:app": "npm-run-all build:release build:debug",
    "release": "npm-run-all test build:app",
    "prepublishOnly": "npm run release",
    "zip": "zip -r KeplerScrollingApp.zip . -x '*.iml' '*.swp' '.idea/*' '*.DS_Store' '.vscode/*' '.tmp/*' 'dist/*' 'build/*' 'node_modules/*' 'buildinfo.json' 'CMakeUserPresets.json' 'npm-debug.log' 'generated/*' 'output/*' '*__pycache__/*' 'bvm/*' '.git/*'"
  },
  "dependencies": {
    "@amazon-devices/kepler-ui-components": "~3.1.0",
    "@amazon-devices/react-native-kepler": "~4.0.0",
    "@amazon-devices/shopify__flash-list": "^2.0.0",
    "@amazon-devices/vega-carousel": "~1.0.0",
    "@babel/runtime": "^7.25.0",
    "@reduxjs/toolkit": "^2.5.0",
    "react": "19.2.0",
    "react-compiler-runtime": "^19.0.0-beta-714736e-20250131",
    "react-native": "0.83.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@amazon-devices/kepler-cli-platform": "~0.22.0",
    "@react-native-community/cli": "^20.0.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.83.0",
    "@testing-library/react-native": "^12.9.0",
    "@tsconfig/react-native": "^3.0.2",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "babel-jest": "^29.6.3",
    "babel-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "eslint": "^8.12.0",
    "eslint-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "jest": "^29.7.0",
    "mustache": "^4.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.2",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.2.5",
    "typescript": "5.8.3"
  },
  "overrides": {
    "zod-validation-error": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "kepler": {
    "projectType": "application",
    "appName": "KeplerScrollingApp",
    "targets": [
      "tv"
    ],
    "os": [
      "vega"
    ],
    "api": 0.1
  }
}
